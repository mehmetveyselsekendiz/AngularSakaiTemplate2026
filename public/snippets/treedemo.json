{
  "tree-basic": "<p-tree [value]=\"treeValue()\" selectionMode=\"checkbox\" [(selection)]=\"selectedTreeValue\"></p-tree>",
  "tree-table": "<p-treetable [value]=\"treeTableValue()\" [columns]=\"cols\" selectionMode=\"checkbox\" [(selectionKeys)]=\"selectedTreeTableValue\" dataKey=\"key\" [scrollable]=\"true\" [tableStyle]=\"{ 'min-width': '50rem' }\">\n    <ng-template #header let-columns>\n        <tr>\n            <th *ngFor=\"let col of columns\">\n                {{ col.header }}\n            </th>\n        </tr>\n    </ng-template>\n    <ng-template #body let-rowNode let-rowData=\"rowData\" let-columns=\"columns\">\n        <tr [ttRow]=\"rowNode\" [ttSelectableRow]=\"rowNode\">\n            <td *ngFor=\"let col of columns; let i = index\">\n                <span class=\"flex items-center gap-2\">\n                    <p-treeTableToggler [rowNode]=\"rowNode\" *ngIf=\"i === 0\" />\n                    <p-treeTableCheckbox [value]=\"rowNode\" *ngIf=\"i === 0\" />\n                    {{ rowData[col.field] }}\n                </span>\n            </td>\n        </tr>\n    </ng-template>\n</p-treetable>"
}
