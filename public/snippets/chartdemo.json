  "chart-bar": "<p-chart type=\"bar\" [data]=\"barData()\" [options]=\"barOptions()\"></p-chart>",
  "chart-pie": "<p-chart type=\"pie\" [data]=\"pieData()\" [options]=\"pieOptions()\"></p-chart>",
  "chart-doughnut": "<p-chart type=\"doughnut\" [data]=\"pieData()\" [options]=\"pieOptions()\"></p-chart>",
